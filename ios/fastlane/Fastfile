default_platform(:ios)

ENV["LANG"] = "en_US.UTF-8"
ENV["LC_ALL"] = "en_US.UTF-8"

PROJECT = "PetitesNuits.xcodeproj"
SCHEME = "PetitesNuits"
SCREENSHOTS_SCHEME = "PetitesNuitsScreenshots"
BUNDLE_ID = "com.bnjdpn.petitesnuits"
TEAM_ID = "767SX34A7Z"

def load_api_key
  api_key_path = File.join(__dir__, "asc_api_key.json")
  api_key_data = JSON.parse(File.read(api_key_path))
  app_store_connect_api_key(
    key_id: ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"] || api_key_data["key_id"],
    issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"] || api_key_data["issuer_id"],
    key_content: ENV["APP_STORE_CONNECT_API_KEY_KEY"] || api_key_data["key"],
    in_house: false
  )
end

def setup_signing(api_key)
  get_certificates(api_key: api_key, platform: "ios")
  get_provisioning_profile(api_key: api_key, app_identifier: BUNDLE_ID, platform: "ios")
  cert_path = lane_context[SharedValues::CERT_FILE_PATH]
  @cert_sha1 = `openssl x509 -inform DER -in "#{cert_path}" -fingerprint -sha1 -noout 2>/dev/null`.strip.split("=").last.gsub(":", "")
  update_code_signing_settings(
    use_automatic_signing: false,
    path: PROJECT,
    team_id: TEAM_ID,
    bundle_identifier: BUNDLE_ID,
    profile_name: lane_context[SharedValues::SIGH_NAME],
    code_sign_identity: @cert_sha1
  )
end

def build_signed_app
  build_app(
    project: PROJECT,
    scheme: SCHEME,
    configuration: "Release",
    export_method: "app-store",
    xcodebuild_formatter: "",
    export_options: {
      signingStyle: "manual",
      teamID: TEAM_ID,
      signingCertificate: @cert_sha1,
      provisioningProfiles: { BUNDLE_ID => lane_context[SharedValues::SIGH_NAME] }
    }
  )
end

before_all do
  Dir.chdir("..") do
    sh("xcodegen generate", error_callback: ->(_result) { UI.user_error!("xcodegen generate failed") }) if File.exist?("project.yml")
  end
end

platform :ios do
  desc "Run unit tests"
  lane :tests do
    run_tests(
      project: PROJECT,
      scheme: SCHEME,
      devices: ["iPhone 17 Pro"],
      clean: false,
      code_coverage: true,
      xcodebuild_formatter: ""
    )
  end

  desc "Generate localized screenshots (FR-only)"
  lane :screenshots do
    capture_screenshots(
      project: PROJECT,
      scheme: SCREENSHOTS_SCHEME,
      output_directory: "./fastlane/screenshots",
      clear_previous_screenshots: true,
      override_status_bar: true,
      xcodebuild_formatter: ""
    )
  end

  desc "Push metadata only (no binary)"
  lane :metadata do
    api_key = load_api_key
    upload_to_app_store(
      api_key: api_key,
      skip_binary_upload: true,
      skip_screenshots: true,
      force: true,
      run_precheck_before_submit: false
    )
  end

  desc "Push screenshots only (no binary, no metadata)"
  lane :upload_screenshots do
    api_key = load_api_key
    upload_to_app_store(
      api_key: api_key,
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: false,
      overwrite_screenshots: true,
      force: true,
      run_precheck_before_submit: false,
      screenshots_path: "./fastlane/screenshots"
    )
  end

  desc "Build & upload to TestFlight"
  lane :beta do
    api_key = load_api_key
    setup_signing(api_key)
    increment_build_number(
      build_number: (latest_testflight_build_number(api_key: api_key) rescue 0) + 1,
      xcodeproj: PROJECT
    )
    build_signed_app
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Full App Store release: build + submit (screenshots + metadata uploaded)"
  lane :release do
    api_key = load_api_key
    setup_signing(api_key)
    increment_build_number(
      build_number: (latest_testflight_build_number(api_key: api_key) rescue 0) + 1,
      xcodeproj: PROJECT
    )
    build_signed_app
    upload_to_app_store(
      api_key: api_key,
      skip_screenshots: false,
      force: true,
      submission_information: { export_compliance_uses_encryption: false },
      submit_for_review: true,
      automatic_release: true,
      run_precheck_before_submit: false
    )
  end

  desc "Quick release without uploading screenshots"
  lane :release_quick do
    api_key = load_api_key
    setup_signing(api_key)
    increment_build_number(
      build_number: (latest_testflight_build_number(api_key: api_key) rescue 0) + 1,
      xcodeproj: PROJECT
    )
    build_signed_app
    upload_to_app_store(
      api_key: api_key,
      skip_screenshots: true,
      skip_metadata: false,
      force: true,
      submission_information: { export_compliance_uses_encryption: false },
      submit_for_review: true,
      automatic_release: true,
      run_precheck_before_submit: false
    )
  end
end
